<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All">
        <MudIcon Icon="@Icons.Material.Filled.SportsVolleyball" Class="me-2" /> Trainings
    </MudNavLink>
    <MudNavLink Href="/training-details" Match="NavLinkMatch.All">
        <MudIcon Icon="@Icons.Material.Filled.BorderColor" Class="me-2" /> Training Details
    </MudNavLink>
    <MudNavLink Href="/player-list" Match="NavLinkMatch.All">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="me-2" /> Players
    </MudNavLink>

    <MudNavGroup Title="Settings">

        <MudNavLink>
            <MudToggleIconButton @bind-Toggled="_isDarkMode"
                                 Icon="@Icons.Material.Filled.DarkMode"
                                 Color="@Color.Warning"
                                 ToggledIcon="@Icons.Material.Filled.LightMode"
                                 title="@(_isDarkMode ? "Light Mode" : "Dark Mode")" />
        </MudNavLink>
    </MudNavGroup>
</MudNavMenu>

<MudThemeProvider />
<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />

@code {
    private readonly MudTheme _theme = new();
    private bool _isDarkMode = true;
}
