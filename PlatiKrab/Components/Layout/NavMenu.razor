<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.Prefix">
        <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" /> Trainings
    </MudNavLink>
    <MudNavLink Href="/training-details" Match="NavLinkMatch.Prefix">
        <MudIcon Icon="@Icons.Material.Filled.FitScreen" /> Training Details
    </MudNavLink>
    <MudNavLink Href="/player-list" Match="NavLinkMatch.Prefix">
        <MudIcon Icon="@Icons.Material.Filled.People" /> Players
    </MudNavLink>

    <MudNavGroup Title="Settings" Expanded="true">

        <MudNavLink>
            <MudToggleIconButton @bind-Toggled="_isDarkMode"
                                 Icon="@Icons.Material.Filled.DarkMode"
                                 Color="@Color.Warning"
                                 ToggledIcon="@Icons.Material.Filled.LightMode"
                                 title="@(_isDarkMode ? "Light Mode" : "Dark Mode")" />
        </MudNavLink>
    </MudNavGroup>
</MudNavMenu>

<MudThemeProvider />
<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />

@code {
    private readonly MudTheme _theme = new();
    private bool _isDarkMode = true;
}
